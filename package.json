{
  "name": "aom",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@types/bun": "^1.3.5",
      "@types/node": "^22.13.14",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "@webgpu/types": "^0.1.71",
      "dotenv": "^17.2.2",
      "hono": "^4.12.27",
      "lucide-react": "^1.21.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "sonner": "^2.0.7",
      "tailwindcss": "^4.3.1",
      "typescript": "^6",
      "zod": "^4.1.13"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev -F web",
    "generate:unit-catalogs": "bun scripts/generate-unit-catalogs.ts",
    "validate:unit-packs": "bun scripts/generate-unit-catalogs.ts --validate-only",
    "check:unit-catalogs": "bun scripts/generate-unit-catalogs.ts --check",
    "check": "bun run check:unit-catalogs && oxlint && oxfmt --write",
    "test": "turbo run test"
  },
  "dependencies": {
    "@aom/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@aom/config": "workspace:*",
    "@types/node": "catalog:",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "turbo": "^2.10.2",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.13"
}
