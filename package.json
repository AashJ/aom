{
  "name": "aom",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@webgpu/types": "^0.1.71",
      "typescript": "^6",
      "@types/node": "^22.13.14",
      "lucide-react": "^1.21.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "sonner": "^2.0.7",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.3.1"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev -F web",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@aom/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@aom/config": "workspace:*",
    "@types/node": "catalog:",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "turbo": "^2.10.2",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.13"
}
